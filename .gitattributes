# Set default behavior to automatic text line ending normalization.
* text=auto

# Explicitly declare text files to always be normalized and shared with LF line endings.
*.kt text
*.kts text
*.xml text
*.properties text
*.gradle text
*.bat text eol=crlf
gradlew text eol=lf

# Denote all files that are truly binary and should not be modified.
*.jar binary
*.png binary
*.jpg binary
*.webp binary
